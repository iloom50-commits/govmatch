# ===== 필수 =====

# Google Gemini AI
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# 공공데이터포털 API 키 (data.go.kr에서 발급)
PUBLIC_DATA_PORTAL_KEY=YOUR_PUBLIC_DATA_PORTAL_API_KEY

# 기업마당(Bizinfo) 포털 API 키 (bizinfo.go.kr에서 발급)
BIZINFO_PORTAL_KEY=YOUR_BIZINFO_PORTAL_KEY

# 관리자 페이지 비밀번호
ADMIN_PASSWORD=your_admin_password

# ===== 공공 API 토큰 (data.go.kr / 기정원) =====

# 중소벤처24 공고정보 API 토큰
SMES24_API_TOKEN=

# 한국식품산업클러스터진흥원 API 키
FOODPOLIS_API_KEY=

# 이노비즈 확인서 API 키
INNOBIZ_API_KEY=

# 벤처기업 확인서 API 키
VENTURE_API_KEY=

# 메인비즈 확인서 API 키
MAINBIZ_API_KEY=

# ===== 웹 푸시 알림 (VAPID) =====
# python -c "from cryptography.hazmat.primitives.asymmetric import ec; ..." 로 생성
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:your@email.com

# ===== CORS 허용 도메인 =====
# 쉼표로 구분, 프로덕션 배포 시 실제 도메인 추가
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== 일일 다이제스트 발송 시각 (0~23) =====
DIGEST_HOUR=9

# ===== SMTP 이메일 발송 (선택) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===== DB 경로 (기본값: 프로젝트 루트의 gov_matching.db) =====
# DB_PATH=gov_matching.db
