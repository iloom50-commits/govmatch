# Google Gemini AI (필수)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# 공공데이터포털 API 키 (필수 - data.go.kr에서 발급)
PUBLIC_DATA_PORTAL_KEY=YOUR_PUBLIC_DATA_PORTAL_API_KEY

# 기업마당(Bizinfo) 포털 API 키 (bizinfo.go.kr에서 발급)
BIZINFO_PORTAL_KEY=YOUR_BIZINFO_PORTAL_KEY

# 중소벤처24 공고정보 API 토큰 (기정원에서 발급)
SMES24_API_TOKEN=

# 한국식품산업클러스터진흥원 API 키
FOODPOLIS_API_KEY=

# SMTP 이메일 발송 설정 (Gmail 예시: 앱 비밀번호 사용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
